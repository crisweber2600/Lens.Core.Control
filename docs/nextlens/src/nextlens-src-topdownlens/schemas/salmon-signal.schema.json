{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lens.local/nextlens/topdownlens/salmon-signal.schema.json",
  "title": "TopDownLens Salmon Signal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source",
    "signal_type",
    "severity",
    "upstream_targets",
    "finding",
    "recommended_action",
    "status",
    "evidence_refs"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^salmon\\.[0-9]{8}T[0-9]{6}Z\\.[a-z0-9][a-z0-9_-]*$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "enum": ["story", "feature", "implementation", "review", "validation"] },
        "id": { "$ref": "landscape-entity.schema.json#/$defs/stableId" }
      }
    },
    "signal_type": {
      "enum": ["assumption_invalidated", "missing_context", "scope_drift", "impact_discovered", "boundary_wrong", "evidence_changed"]
    },
    "severity": { "enum": ["low", "medium", "high", "blocking"] },
    "upstream_targets": {
      "type": "array",
      "items": { "enum": ["feature", "journey", "outcome", "product_area", "landscape"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "finding": { "type": "string", "minLength": 1 },
    "recommended_action": {
      "enum": ["local_note", "landscape_update", "bmad_correct_course", "split_feature", "block_promotion"]
    },
    "status": { "enum": ["open", "accepted", "rejected", "resolved", "superseded"] },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "landscape-entity.schema.json#/$defs/stableId" },
      "minItems": 1,
      "uniqueItems": true
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resolved_by": { "type": "string" },
        "resolved_at": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    }
  }
}